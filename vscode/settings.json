  // --------------------------------------
  // VSCode Animations:
  // --------------------------------------
  // Hiệu ứng animation khi mở Command Palette (Ctrl/Cmd + Shift + P)
  "animations.Command-Palette": "Slide", // None | Scale | Slide | Fade

  // Hiệu ứng animation khi chuyển / mở tab editor
  "animations.Tabs": "Scale", // None | Scale | Slide | Flip

  // Hiệu ứng animation khi cuộn nội dung
  "animations.Scrolling": "None", // None | Scale | Slide | Fade

  // Hiệu ứng cho item đang active (tab / item được focus)
  "animations.Active": "Indent", // None | Scale | Indent

  // Bật animation cho con trỏ khi editor mất focus
  "animations.CursorAnimation": false,

  // Tuỳ chọn chi tiết cho animation con trỏ
  "animations.CursorAnimationOptions": {
    // Màu của hiệu ứng con trỏ (sẽ bị override nếu dùng cursor color)
    "Color": "#333",

    // Kiểu con trỏ dùng cho animation
    "CursorStyle": "line",

    // Độ dài “vệt” animation theo sau con trỏ
    "TrailLength": 8
  },

  // Dùng màu con trỏ hiện tại thay vì màu custom ở trên
  "animations.UseCursorColorForCursorAnimation": true,

