  // --------------------------------------
  //  ryuta46.multi-command
  // --------------------------------------
  "multiCommand.commands": [
    {
      "command": "multiCommand.runGitLog",
      "sequence": [
        "workbench.action.terminal.focus",
        "workbench.action.terminal.new",
        {
          "command": "workbench.action.terminal.sendSequence",
          "args": { "text": "git log --oneline\n" }
        }
      ]
    },
    {
      "command": "multiCommand.runGitPush",
      "sequence": [
        "workbench.action.terminal.focus",
        "workbench.action.terminal.new",
        {
          "command": "workbench.action.terminal.sendSequence",
          "args": {
            "text": "git push -u origin $(git branch --show-current)\n"
          }
        }
      ]
    },
    {
      "command": "multiCommand.runGitPull",
      "sequence": [
        "workbench.action.terminal.focus",
        "workbench.action.terminal.new",
        {
          "command": "workbench.action.terminal.sendSequence",
          "args": {
            "text": "git pull origin $(git branch --show-current)\n"
          }
        }
      ]
    }
  ],

