  "animations.Focus-Dimming-Amount": 100,

  // Phạm vi làm mờ khi mất focus
  "animations.Focus-Dimming-Mode": "Editor", // Full Window | Editor | Tab

  // Cách extension inject animation (Custom CSS & JS)
  "animations.Install-Method": "Custom CSS and JS",

